[0m18:20:26.222602 [debug] [Thread-4 (]: On model.retize_dbt.stg_tiktok_posts: /* {"app": "dbt", "dbt_version": "1.7.9", "profile_name": "retize_dbt", "target_name": "dev", "node_id": "model.retize_dbt.stg_tiktok_posts"} */

  create view "retize_dw"."social_media_staging"."stg_tiktok_posts__dbt_tmp"
    
    
  as (
    with source as (

    select *
    from "retize_dw"."social_media_raw"."raw_tiktok_posts"

),

final as (

    select
        item_id as id,
        business_username as username,

        -- timestamp padronizado
        cast(create_time as timestamp) - interval '3 hours' as create_time,

        -- dia da semana pt-br
        case extract(dow from cast(create_time as timestamp) - interval '3 hours')
            when 0 then 'domingo'
            when 1 then 'segunda'
            when 2 then 'terca'
            when 3 then 'quarta'
            when 4 then 'quinta'
            when 5 then 'sexta'
            when 6 then 'sabado'
        end as create_day_of_week,

        cast(likes as int) as likes,
        cast(comments as int) as comments,
        cast(shares as int) as shares,
        cast(video_views as int) as video_views,
        cast(reach as int) as reach,
        cast(favorites as int) as favorites,
        cast(profile_views as int) as profile_views,
        cast(new_followers as int) as new_followers,
        cast(total_time_watched as int) as total_time_watched,
        cast(average_time_watched as float) as average_time_watched,
        cast(full_video_watched_rate as float) as full_video_watched_rate,
        cast(video_duration as float) as video_duration,
        cast(app_download_clicks as int) as app_download_clicks,
        cast(lead_submissions as int) as lead_submissions,
        cast(phone_number_clicks as int) as phone_number_clicks,
        cast(website_clicks as int) as website_clicks

    from source

)

select * from final
  );
