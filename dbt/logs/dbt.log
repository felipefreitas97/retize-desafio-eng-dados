  create  table "retize_dw"."social_media_analytics"."mart_posts_enriched__dbt_tmp"
  
  
    as
  
  (
    with instagram as (

    select
        m.id,
        'instagram' as platform,
        m.username,
        m.timestamp,

        -- fallback de likes
        coalesce(i.likes, m.like_count) as likes,

        coalesce(i.comments, m.comments_count) as comments,
        i.shares,
        i.reach,
        i.views

    from "retize_dw"."social_media_staging"."stg_instagram_media" m
    left join "retize_dw"."social_media_staging"."stg_instagram_media_insights" i
        on m.id = i.id

),

tiktok as (

    select
        id,
        'tiktok' as platform,
        username,
        timestamp,

        likes,
        comments,
        shares,
        reach,
        video_views as views

    from "retize_dw"."social_media_staging"."stg_tiktok_posts"

),

unioned as (

    select * from instagram
    union all
    select * from tiktok

),

final as (

    select
        *,
        
        -- métrica principal
        coalesce(likes, 0)
        + coalesce(comments, 0)
        + coalesce(shares, 0) as engagement,

        -- métrica mais avançada
        case 
            when reach > 0 then
                (coalesce(likes, 0)
                + coalesce(comments, 0)
                + coalesce(shares, 0))::float / reach
            else null
        end as engagement_rate

    from unioned

)

select * from final
  );
  
