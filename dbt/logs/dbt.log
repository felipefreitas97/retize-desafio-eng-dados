        on c.id = m.id

),

tiktok as (

    select
        c.comment_id,
        c.id as post_id,
        'tiktok' as platform,
        p.username,
        c.comment_timestamp,
        c.day_of_week,

        c.predicted_sentiment,
        c.sentiment_value,
        c.confidence_sentiment,
