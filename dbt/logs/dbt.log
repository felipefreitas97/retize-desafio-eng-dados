[0m19:12:37.799048 [debug] [Thread-4 (]: On model.retize_dbt.mart_posts_enriched: /* {"app": "dbt", "dbt_version": "1.7.9", "profile_name": "retize_dbt", "target_name": "dev", "node_id": "model.retize_dbt.mart_posts_enriched"} */

  
    

  create  table "retize_dw"."social_media_analytics"."mart_posts_enriched__dbt_tmp"
  
  
    as
  
  (
    with instagram as (

    select
        m.id,
        'instagram' as platform,
        m.username,
        m.timestamp,

        trim(to_char(m.timestamp, 'Day')) as day_of_week,

        -- métricas base
        coalesce(i.likes, m.like_count) as likes,
        coalesce(i.comments, m.comments_count) as comments,
        coalesce(i.shares, 0) as shares,
        coalesce(i.saved, 0) as saves,  -- corrigido (saved → saves)
        coalesce(i.reach, 0) as reach

    from "retize_dw"."social_media_staging"."stg_instagram_media" m
    left join "retize_dw"."social_media_staging"."stg_instagram_media_insights" i
        on m.id = i.id

),

tiktok_base as (

    -- aqui resolvemos o problema do alias
    select
        id,
        username,
        create_time as timestamp,
        likes,
        comments,
        shares,
        favorites,
        reach
    from "retize_dw"."social_media_staging"."stg_tiktok_posts"

),

tiktok as (

    select
        id,
        'tiktok' as platform,
        username,
        timestamp,

        trim(to_char(timestamp, 'Day')) as day_of_week,

        -- métricas base
        coalesce(likes, 0) as likes,
        coalesce(comments, 0) as comments,
        coalesce(shares, 0) as shares,
        coalesce(favorites, 0) as saves,  -- padronização
        coalesce(reach, 0) as reach

    from tiktok_base

),

unioned as (

    select * from instagram
    union all
    select * from tiktok

),

final as (

    select
        id,
        platform,
        username,
        timestamp,
        day_of_week,
        likes,
        comments,
        shares,
        saves,
        reach,

        -- fórmula de engajamento
        case 
            when reach > 0 then
                (
                    (likes * 1) +
                    (comments * 3) +
                    (shares * 4) +
                    (saves * 3)
                )::float / reach
            else 0
        end as engagement

    from unioned

)

select * from final
  );
  
[0m19:12:37.800048 [debug] [Thread-2 (]: On model.retize_dbt.mart_comments_enriched: /* {"app": "dbt", "dbt_version": "1.7.9", "profile_name": "retize_dbt", "target_name": "dev", "node_id": "model.retize_dbt.mart_comments_enriched"} */

  
    

  create  table "retize_dw"."social_media_analytics"."mart_comments_enriched__dbt_tmp"
  
  
    as
  
  (
    with instagram as (

    select
        c.comment_id::text as comment_id,
        c.id::text as post_id,
        'instagram'::text as platform,
        coalesce(m.username, '')::text as username,
        c.comment_timestamp::timestamp as comment_timestamp,
        c.day_of_week::text as day_of_week,

        c.predicted_sentiment::text as predicted_sentiment,
        c.sentiment_value::int as sentiment_value,
        c.confidence_sentiment::double precision as confidence_sentiment,
        c.value_sentiment::double precision as value_sentiment

    from "retize_dw"."social_media_staging"."stg_instagram_comments" c
    left join "retize_dw"."social_media_staging"."stg_instagram_media" m
        on c.id = m.id

),

tiktok as (

    select
        c.comment_id::text as comment_id,
        c.id::text as post_id,
        'tiktok'::text as platform,
        coalesce(p.username, '')::text as username,
        c.comment_timestamp::timestamp as comment_timestamp,
        c.day_of_week::text as day_of_week,

        c.predicted_sentiment::text as predicted_sentiment,
        c.sentiment_value::int as sentiment_value,
        c.confidence_sentiment::double precision as confidence_sentiment,
        c.value_sentiment::double precision as value_sentiment

    from "retize_dw"."social_media_staging"."stg_tiktok_comments" c
    left join "retize_dw"."social_media_staging"."stg_tiktok_posts" p
        on c.id = p.id

)

select
    comment_id,
    post_id,
    platform,
    username,
    comment_timestamp,
    day_of_week,
    predicted_sentiment,
    sentiment_value,
    confidence_sentiment,
    value_sentiment
from instagram

union all

select
    comment_id,
    post_id,
    platform,
    username,
    comment_timestamp,
    day_of_week,
    predicted_sentiment,
    sentiment_value,
    confidence_sentiment,
    value_sentiment
from tiktok
  );
  
