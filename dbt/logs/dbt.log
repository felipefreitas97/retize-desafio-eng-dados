        cast(app_download_clicks as int) as app_download_clicks,
        cast(lead_submissions as int) as lead_submissions,
        cast(phone_number_clicks as int) as phone_number_clicks,
        cast(website_clicks as int) as website_clicks

    from source

)

select * from final
  );
