  create  table "retize_dw"."social_media_analytics"."mart_comments_enriched__dbt_tmp"
  
  
    as
  
  (
    with instagram as (

    select
        c.comment_id::text as comment_id,
        c.id::text as post_id,
        'instagram'::text as platform,
        coalesce(m.username, '')::text as username,
        c.comment_timestamp::timestamp as comment_timestamp,
        c.day_of_week::text as day_of_week,

        c.predicted_sentiment::text as predicted_sentiment,
        c.sentiment_value::int as sentiment_value,
        c.confidence_sentiment::double precision as confidence_sentiment,
        c.value_sentiment::double precision as value_sentiment

    from "retize_dw"."social_media_staging"."stg_instagram_comments" c
    left join "retize_dw"."social_media_staging"."stg_instagram_media" m
        on c.id = m.id

),

tiktok as (

    select
        c.comment_id::text as comment_id,
        c.id::text as post_id,
        'tiktok'::text as platform,
        coalesce(p.username, '')::text as username,
        c.comment_timestamp::timestamp as comment_timestamp,
        c.day_of_week::text as day_of_week,

        c.predicted_sentiment::text as predicted_sentiment,
        c.sentiment_value::int as sentiment_value,
        c.confidence_sentiment::double precision as confidence_sentiment,
        null::double precision as value_sentiment

    from "retize_dw"."social_media_staging"."stg_tiktok_comments" c
    left join "retize_dw"."social_media_staging"."stg_tiktok_posts" p
        on c.id = p.id

)

select
    comment_id,
    post_id,
    platform,
    username,
    comment_timestamp,
    day_of_week,
    predicted_sentiment,
    sentiment_value,
    confidence_sentiment,
    value_sentiment
from instagram

union all

select
    comment_id,
    post_id,
    platform,
    username,
    comment_timestamp,
    day_of_week,
    predicted_sentiment,
    sentiment_value,
    confidence_sentiment,
    value_sentiment
from tiktok
  );
  
